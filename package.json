{
  "name": "cli_chat_boilerplate",
  "version": "1.0.0",
  "description": "Boilerplate for building CLI chat agents",
  "main": "dist/main.js",
  "bin": {
    "cli-chat": "./dist/main.js"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
