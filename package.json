    "@nestjs/core": "^11.1.23",
    "cli-color": "^2.0.4",
    "nest-commander": "^3.15.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@types/cli-color": "^2.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.9",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
